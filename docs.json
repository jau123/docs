{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MeiGen Docs",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#6D28D9"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/gallery",
              "features/generate",
              "features/prompt-enhance",
              "features/models"
            ]
          },
          {
            "group": "MCP Plugin",
            "pages": [
              "mcp/overview",
              "mcp/setup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/generate",
              "api-reference/endpoint/models",
              "api-reference/endpoint/images",
              "api-reference/endpoint/tokens"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Gallery",
          "href": "https://www.meigen.ai",
          "icon": "images"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/jau123/MeiGen-AI-Design-MCP",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Gallery",
        "href": "https://www.meigen.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.meigen.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/user_jau",
      "github": "https://github.com/jau123/MeiGen-AI-Design-MCP"
    }
  }
}
